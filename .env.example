# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit it.
#
# Reference these variables in config.yaml as ${VAR_NAME}, e.g.:
#   username: ${MQTT_USER}
#   "rtsp://${CAM1_USER}:${CAM1_PASS}@192.168.1.101/stream1"

# MQTT broker credentials
MQTT_USER=mqtt_user
MQTT_PASS=changeme

# Camera credentials
CAM1_USER=admin
CAM1_PASS=changeme

CAM2_USER=admin
CAM2_PASS=changeme

# Copy this file to .env and fill in your camera credentials.
# .env is gitignored — never commit it.
#
# Reference these variables in config.yaml as ${VAR_NAME}, e.g.:
#   "rtsp://${CAM1_USER}:${CAM1_PASS}@192.168.1.101/stream1"

CAM1_USER=admin
CAM1_PASS=changeme

CAM2_USER=admin
CAM2_PASS=changeme
